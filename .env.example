# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-anon-key
# Chave de serviço (service_role) — usada apenas no servidor para operações admin (ex: excluir usuários)
# Encontre em: Supabase Dashboard > Project Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=sua-service-role-key

# URL pública da aplicação — usada no link de convite enviado por e-mail
# Em produção, altere para a URL real (ex: https://meuapp.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Database (para Prisma, se usar)
DATABASE_URL="postgresql://user:password@host:5432/database?schema=public"
DIRECT_URL="postgresql://user:password@host:5432/database?schema=public"
